# NFTMail.box Environment Variables
# Copy to .env.local and fill in real values
# Never commit .env files to git

# === App Configuration ===
NEXT_PUBLIC_APP_URL=https://nftmail.box
NEXT_PUBLIC_WORKER_URL=https://your-worker.your-subdomain.workers.dev

# === Email Provider (Mailgun Foundation) ===
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=mg.nftmail.box
MAILGUN_WEBHOOK_SIGNING_KEY=your-webhook-signing-key

# === Privy Auth ===
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret

# === Blockchain RPC ===
GNOSIS_RPC_URL=https://rpc.gnosischain.com
ETH_RPC_URL=https://mainnet.infura.io/v3/your-key

# === IPFS (Lighthouse) ===
LIGHTHOUSE_API_KEY=your-lighthouse-api-key

# === Webhook Security ===
WEBHOOK_SECRET=your-webhook-secret

# === Monitoring ===
SENTRY_DSN=your-sentry-dsn
